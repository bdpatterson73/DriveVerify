<Window x:Class="DriveVerify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DriveVerify"
        xmlns:views="clr-namespace:DriveVerify.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="900" MinHeight="600" MinWidth="750"
        Background="{StaticResource WindowBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="images/DriveVerify.ico">
    <Grid x:Name="MainGrid" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Drive Selection + Test Settings -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Drive Selection -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Drive Selection" Style="{StaticResource SectionHeader}" />
                    <ComboBox ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding SelectedDrive}"
                              IsEnabled="{Binding IsNotRunning}"
                              Margin="0,0,0,8" />
                    <Button Content="⟳ Refresh Drives"
                            Command="{Binding RefreshDrivesCommand}"
                            IsEnabled="{Binding IsNotRunning}"
                            Margin="0,0,0,8" />
                    <TextBlock Text="{Binding DriveInfoText}"
                               Foreground="{StaticResource SubtleForeground}"
                               FontSize="11.5" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding DriveWarning}"
                               Foreground="#FF9800" FontWeight="SemiBold"
                               Margin="0,4,0,0"
                               Visibility="{Binding DriveWarning, Converter={StaticResource StringToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <!-- Test Settings -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Test Settings" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding TestModes}"
                                  SelectedItem="{Binding SelectedTestMode}"
                                  IsEnabled="{Binding IsNotRunning}" Margin="0,0,0,6" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Block size (MB):" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding BlockSizeMB, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}" Margin="0,0,0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Test size (GB):" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CustomTestSizeGB, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 IsEnabled="{Binding IsNotRunning}" Margin="0,0,0,6" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Verify threads:" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding VerifyThreadCount, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsNotRunning}" Margin="0,0,0,0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="▶ Start Test"
                                Command="{Binding StartTestCommand}"
                                Width="110" Margin="0,0,8,0"
                                FontWeight="SemiBold" />
                        <Button Content="✖ Cancel"
                                Command="{Binding CancelCommand}"
                                Width="90" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="📄 Open Report"
                                Command="{Binding OpenReportCommand}"
                                Margin="0,0,8,0"
                                ToolTip="Open the HTML test report" />
                        <Button Content="🗑 Clean Up Test Files"
                                Command="{Binding CleanUpCommand}"
                                ToolTip="Delete all test files from the drive" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 1: Progress -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Progress" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding PhaseText}" FontWeight="SemiBold" Margin="0,0,12,0" />
                    <ProgressBar Grid.Column="1" Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                 Height="18" />
                    <TextBlock Grid.Column="2" Margin="12,0,0,0">
                        <Run Text="{Binding ProgressPercent, StringFormat={}{0:F1}%}" />
                    </TextBlock>
                </Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding BlockProgressText}" Margin="0,0,16,0"
                               Foreground="{StaticResource SubtleForeground}" FontSize="11.5" />
                    <TextBlock Margin="0,0,16,0" Foreground="{StaticResource SubtleForeground}" FontSize="11.5">
                        <Run Text="Speed:" /> <Run Text="{Binding SpeedText, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Margin="0,0,16,0" Foreground="{StaticResource SubtleForeground}" FontSize="11.5">
                        <Run Text="Elapsed:" /> <Run Text="{Binding ElapsedText, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource SubtleForeground}" FontSize="11.5">
                        <Run Text="ETA:" /> <Run Text="{Binding EtaText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Heatmap -->
        <Border x:Name="HeatmapBorder" Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                MouseLeftButtonDown="HeatmapBorder_MouseDoubleClick" Cursor="Hand">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Heatmap" Style="{StaticResource SectionHeader}" Margin="0" DockPanel.Dock="Left" />
                    <TextBlock x:Name="HeatmapHintText" Text="Double-click to expand"
                               FontSize="10.5" Foreground="{StaticResource SubtleForeground}"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </DockPanel>

                <!-- Heatmap (will expand to fill) -->
                <views:HeatmapControl x:Name="HeatmapView" Grid.Row="1" RegionStatuses="{Binding RegionStatuses}" Height="48" />

                <!-- Legend -->
                <StackPanel x:Name="HeatmapLegend" Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <Border Width="12" Height="12" Background="#3C3C3C" CornerRadius="2" Margin="0,0,4,0" />
                    <TextBlock Text="Untested" FontSize="10.5" Foreground="{StaticResource SubtleForeground}" Margin="0,0,12,0" />
                    <Border Width="12" Height="12" Background="#2196F3" CornerRadius="2" Margin="0,0,4,0" />
                    <TextBlock Text="Writing" FontSize="10.5" Foreground="{StaticResource SubtleForeground}" Margin="0,0,12,0" />
                    <Border Width="12" Height="12" Background="#FF9800" CornerRadius="2" Margin="0,0,4,0" />
                    <TextBlock Text="Verifying" FontSize="10.5" Foreground="{StaticResource SubtleForeground}" Margin="0,0,12,0" />
                    <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="2" Margin="0,0,4,0" />
                    <TextBlock Text="Good" FontSize="10.5" Foreground="{StaticResource SubtleForeground}" Margin="0,0,12,0" />
                    <Border Width="12" Height="12" Background="#F44336" CornerRadius="2" Margin="0,0,4,0" />
                    <TextBlock Text="Bad" FontSize="10.5" Foreground="{StaticResource SubtleForeground}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 3: Verdict Banner -->
        <Border Grid.Row="3" Background="{Binding VerdictBrush}" CornerRadius="8" Padding="16"
                Margin="0,0,0,12"
                Visibility="{Binding VerdictVisibility}">
            <TextBlock Text="{Binding VerdictText}"
                       Foreground="{Binding VerdictForeground}"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- Row 4: Log Output -->
        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Log" Style="{StaticResource SectionHeader}" />
                <ListBox ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource SubtleForeground}"
                         FontFamily="Consolas" FontSize="11.5"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         x:Name="LogListBox" />
            </DockPanel>
        </Border>

        <!-- Row 5: Status Bar -->
        <Border Grid.Row="5" Background="#1A1A1A" CornerRadius="4" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubtleForeground}" FontSize="11.5" Margin="0,0,16,0" />
                <TextBlock Foreground="{StaticResource SubtleForeground}" FontSize="11.5">
                    <Run Text="Drive:" />
                    <Run Text="{Binding SelectedDrive.DriveLetter, Mode=OneWay, FallbackValue='—'}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource SubtleForeground}" FontSize="11.5" Margin="16,0,0,0">
                    <Run Text="Free:" />
                    <Run Text="{Binding SelectedDrive.FreeSpace, Mode=OneWay, FallbackValue='—', Converter={StaticResource BytesToSizeConverter}}" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
